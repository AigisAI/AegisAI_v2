PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegisai
REDIS_URL=redis://localhost:6379
SESSION_SECRET=replace-with-a-strong-session-secret
CSRF_SECRET=replace-with-a-strong-csrf-secret
SESSION_COOKIE_NAME=connect.sid
CSRF_COOKIE_NAME=csrf_token
COOKIE_DOMAIN=
# Generate a unique 64-character hex key per environment: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_YOUR_OWN_64_HEX_CHARACTER_KEY
GITHUB_CLIENT_ID=github-client-id
GITHUB_CLIENT_SECRET=github-client-secret
GITLAB_CLIENT_ID=gitlab-client-id
GITLAB_CLIENT_SECRET=gitlab-client-secret
ANALYSIS_CLIENT_MODE=mock
AI_SERVER_URL=http://localhost:8000
USE_INTERNAL_AI=false
INTERNAL_API_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=
REPORT_STORAGE_PATH=./tmp/reports
REPORT_EXPIRY_HOURS=24
REPORT_EXPIRY_INTERVAL_MS=900000
TEAMS_WEBHOOK_URL=
