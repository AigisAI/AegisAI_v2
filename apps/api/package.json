{
  "name": "@aegisai/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "corepack pnpm prisma:generate && nest build",
    "dev": "corepack pnpm prisma:generate && nest start --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "start": "node dist/main.js",
    "test": "corepack pnpm prisma:generate && jest --config ./test/jest-e2e.json",
    "test:e2e": "corepack pnpm prisma:generate && jest --config ./test/jest-e2e.json",
    "typecheck": "corepack pnpm prisma:generate && tsc --noEmit",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@aegisai/shared": "workspace:*",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.15",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^5.2.0",
    "@prisma/client": "5",
    "axios": "^1.13.2",
    "bullmq": "^5.61.0",
    "connect-redis": "^8.1.0",
    "cookie-parser": "^1.4.7",
    "express-session": "^1.18.1",
    "joi": "^18.0.2",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-gitlab2": "^5.0.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
