{
  "name": "@aegisai/ai",
  "version": "0.1.0",
  "private": true,
  "main": "dist/src/server.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "corepack pnpm --filter @aegisai/shared build && tsc -p tsconfig.json",
    "dev": "corepack pnpm build && node dist/src/server.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "start": "node dist/src/server.js",
    "test": "corepack pnpm build && node --test dist/test/*.test.js",
    "typecheck": "corepack pnpm --filter @aegisai/shared build && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aegisai/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
