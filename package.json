{
  "name": "aegisai-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev": "corepack pnpm --parallel --filter @aegisai/api --filter @aegisai/web dev",
    "dev:api": "corepack pnpm --filter @aegisai/api dev",
    "dev:web": "corepack pnpm --filter @aegisai/web dev",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test && node --test test/github-actions/*.test.mjs",
    "test:ci-workflow": "node --test test/github-actions/*.test.mjs",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
